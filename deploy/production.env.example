COMPOSE_PROJECT_NAME=xianyu-auto-reply

# Image registry. GitHub Actions updates per-service tags on deploy.
BACKEND_WEB_IMAGE=ghcr.io/endlessjy/xianyu-auto-reply-backend-web
WEBSOCKET_IMAGE=ghcr.io/endlessjy/xianyu-auto-reply-websocket
SCHEDULER_IMAGE=ghcr.io/endlessjy/xianyu-auto-reply-scheduler
FRONTEND_IMAGE=ghcr.io/endlessjy/xianyu-auto-reply-frontend
IMAGE_TAG=latest
BACKEND_WEB_IMAGE_TAG=latest
WEBSOCKET_IMAGE_TAG=latest
SCHEDULER_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Official multi-arch base images are required for the arm64 server.
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine

# Persistent data lives below the deployment directory.
DATA_DIR=/mnt/sdb/xianyu-auto-reply/data

# Database and Redis passwords are generated by scripts/remote-deploy-ghcr.sh
# on first deployment. Do not commit real values here.
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=xianyu_data
MYSQL_USER=xianyu
MYSQL_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0

# Only the frontend is public by default. API services bind to 127.0.0.1.
FRONTEND_PORT=9000
BACKEND_WEB_PORT=18089
WEBSOCKET_PORT=18090
SCHEDULER_PORT=18091

BACKEND_WEB_PUBLIC_URL=http://129.150.62.28:9000
FRONTEND_PUBLIC_URL=http://129.150.62.28:9000
CORS_ORIGINS=http://129.150.62.28:9000

LOG_LEVEL=INFO
SQL_ECHO=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REDELIVERY_INTERVAL=5
RATE_INTERVAL=20
MAX_CAPTCHA_CONCURRENT=3
AUTO_START_WEBSOCKET=true
CAPTCHA_DRISSIONPAGE_FALLBACK_ENABLED=true
CAPTCHA_DRISSIONPAGE_TIMEOUT=25
CAPTCHA_DRISSIONPAGE_HEADLESS=true
AUTO_START_CRAWL_JOBS=false

CARD_DOCK_BASE_URL=http://backend.zhinianboke.com
EXTERNAL_API_KEY=CHANGE_ME
REMOTE_OFFICIAL_BASE_URL=https://xy.zhinianboke.com
ENABLE_REMOTE_ADS=false
ENABLE_REMOTE_ANNOUNCEMENTS=false
